# ============================================================
# IBKR Connection (TWS API)
# ============================================================
IBKR_HOST=127.0.0.1
IBKR_TWS_PORT=4002          # 4002=paper trading, 4001=live trading
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=U1234567       # Your IBKR account number

# ============================================================
# Claude / Anthropic
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./portfolioiq.db

# ============================================================
# Application
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================================
# Scheduler
# ============================================================
SYNC_INTERVAL_MINUTES=5
QUOTE_REFRESH_SECONDS=60
OHLCV_CACHE_TTL_HOURS=24
FUNDAMENTAL_CACHE_TTL_HOURS=6

# ============================================================
# Research Agent
# ============================================================
RESEARCH_CACHE_TTL_HOURS=24
RESEARCH_DAILY_CALL_LIMIT=20
RESEARCH_MODEL=claude-opus-4-5
SIGNAL_MODEL=claude-sonnet-4-5
